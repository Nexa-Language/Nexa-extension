{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    {"open": "{", "close": "}"},
    {"open": "[", "close": "]"},
    {"open": "(", "close": ")"},
    {"open": "\"", "close": "\""},
    {"open": "\"\"\"", "close": "\"\"\""}
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "colorizedBracketPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#?region\\b",
      "end": "^\\s*//\\s*#?endregion\\b"
    }
  },
  "wordPattern": "([a-zA-Z_][a-zA-Z0-9_]*|@?[a-zA-Z_][a-zA-Z0-9_]*)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(agent|tool|flow|protocol|test|if|else|loop|try|catch|match|semantic_if)\\b.*\\{[^}]*$",
    "decreaseIndentPattern": "^\\s*\\}"
  }
}
