{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nexa Secrets",
  "scopeName": "source.nexa.secrets",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#config-block"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keys"
    },
    {
      "include": "#values"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nexa.secrets",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nexa.secrets",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "config-block": {
      "patterns": [
        {
          "match": "\\b(config)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\{",
          "captures": {
            "1": {
              "name": "keyword.declaration.config.nexa.secrets"
            },
            "2": {
              "name": "entity.name.namespace.config.nexa.secrets"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nexa.secrets",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nexa.secrets",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keys": {
      "patterns": [
        {
          "match": "\\b([A-Z][A-Z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "variable.other.constant.key.nexa.secrets"
            },
            "2": {
              "name": "keyword.operator.assignment.nexa.secrets"
            }
          }
        }
      ]
    },
    "values": {
      "patterns": [
        {
          "name": "constant.numeric.nexa.secrets",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        {
          "name": "constant.language.boolean.nexa.secrets",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "punctuation.bracket.nexa.secrets",
          "match": "[{\\[\\(\\)}\\]]"
        },
        {
          "name": "punctuation.separator.nexa.secrets",
          "match": ","
        },
        {
          "name": "punctuation.accessor.nexa.secrets",
          "match": ":"
        }
      ]
    }
  }
}