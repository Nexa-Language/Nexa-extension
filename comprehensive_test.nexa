// join 函数 - 多 Agent 结果合并
flow join_test() {
    final_report = join(Researcher_Tech, Researcher_Biz).Summarizer("Synthesize");
}

// img 函数 - 图像处理
flow img_test() {
    img_data = img("docs/img/logo.jpg");
    result = VisionAgent.run("Inspect this image", img_data);
}

// secret 函数 - 密钥获取
flow secret_test() {
    my_key = secret("MY_TEST_KEY");
    print(my_key);
}

// fallback 表达式 - 容错处理
flow fallback_test() {
    result = Agent.run("test") fallback "Fallback Triggered";
}

// Agent 返回类型声明
agent TypedAgent -> str {
    prompt: "Returns a string"
}

agent GenericAgent -> Result<Data> {
    prompt: "Returns generic type"
}

// Agent uses 多种形式
agent McpAgent uses mcp:"http://fake.url" {
    model: "dummy_model"
}

agent StdAgent uses std.shell {
    prompt: "Uses std shell"
}

agent MultiToolAgent uses Tool1, Tool2, Tool3 {
    prompt: "Uses multiple tools"
}

// description 属性
agent DescribedAgent {
    description: "This is a described agent",
    model: "gpt-4"
}

