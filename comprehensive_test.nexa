// 这是 Nexa 的综合测试文件，用于测试语法高亮

/*
 多行注释测试
*/

include "stdlib.nexa";

agent FriendlyBot {
    role: "Casual conversationalist",
    model: "minimax/minimax-m2.5",
    prompt: """
    You are a very friendly ChatBot for casual conversations.
    This is a multi-line string.
    """
}

tool SearchGlobal {
    description: "Search tool",
    parameters: {
        "query": "string"
    }
}

tool MCPTool {
    mcp: "github.com/repo/mcp-server"
}

tool PythonTool {
    python: "def execute(): pass"
}

flow main_flow() {
    print("Hello, Nexa!");
    
    // 测试控制流
    if (true) {
        assert true;
    } else {
        assert false;
    }

    loop {
        try {
            print("trying...");
        } catch (e) {
            print(e);
        }
    } until (false);
}

flow dag_flow() {
    // 管道
    result = input >> Agent1 >> Agent2;

    // 分叉
    results = input |>> [Agent1, Agent2, Agent3];

    // Fire-and-Forget
    input || [Agent1, Agent2];

    // 合流
    result = [Agent1, Agent2] &>> MergerAgent;

    // 共识合流
    result = [Agent1, Agent2] && ConsensusAgent;

    // 条件分支
    result = input ?? TrueAgent : FalseAgent;
}

flow number_test() {
    val1 = 42;
    val2 = 3.14;
}

// 确保所有的关键字都用高亮表示
flow all_keywords_test() {
    print("Testing");
}

