agent StringBoolAgent {
    stream: "true",
    cache: "false",
    memory: "persistent"
}

// ============================================
// runtime.meta 内置变量测试
// ============================================

flow runtime_meta_test() {
    loop {
        draft = Writer.run("task");
        feedback = Reviewer.run(draft);
    } until ("Code has 0 bugs" or runtime.meta.loop_count >= 4)

    if (runtime.meta.loop_count >= 4) {
        print("Max iterations reached");
        print(runtime.meta.last_result);
    }
}

// ============================================
// raise 异常抛出测试
// ============================================

flow raise_test() {
    if (error_condition) {
        raise SuspendExecution("Need Human Check");
    }
}

