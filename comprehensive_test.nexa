}

// clone 方法 - 运行时动态反射
flow clone_test() {
    SuperAgent = BaseAgent.clone(new_name="SuperAgent", model="gpt-4");
    result = SuperAgent.run("Hello from clone!");
}

// 字典访问语法
flow dict_access_test() {
    config = secret("CONFIG");
    value = config["subkey"];
    nested = secret("DATA")["level1"]["level2"];
}

// 二元运算符 (+ 字符串拼接)
flow binary_op_test() {
    greeting = "Hello" + " " + "World";
    combined = prefix + suffix;
}

// ============================================
// 标准库完整测试
// ============================================

// std.fs - 文件系统
agent FileAssistant uses std.fs {
    role: "文件管理助手",
    prompt: "管理文件"
}

// std.http - HTTP 请求
agent WebScraper uses std.http {
    role: "网页抓取助手",
    prompt: "抓取网页"
}

// std.time - 时间系统
agent TimeBot uses std.time {
    role: "时间助手",
    prompt: "处理时间"
}

// std.shell - 系统终端
agent ShellBot uses std.shell {
    role: "终端助手",
    prompt: "执行命令"
}

// std.ask_human - 人机交互
agent HumanBot uses std.ask_human {
    role: "人机交互",
    prompt: "与人类交互"
}

// std.json - JSON 处理
agent JsonBot uses std.json {
    role: "JSON助手",
    prompt: "处理JSON"
}

// std.math - 数学运算
agent MathBot uses std.math {
    role: "数学助手",
    prompt: "数学计算"
}

// 多标准库组合
agent SuperBot uses std.fs, std.http, std.time, std.shell {
    role: "超级助手",
    prompt: "全能助手"
}

// ============================================
// Protocol 类型系统测试
// ============================================

protocol ComplexType {
    name: "string",
    age: "int",
    score: "float",
    active: "boolean",
    tags: "list[string]",
    numbers: "list[int]",
    metadata: "dict"
}

// Agent 实现协议
agent TypedReviewer implements ComplexType {
    prompt: "Review with structured output"
}

