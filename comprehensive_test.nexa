// ============================================
// 变量赋值测试
// ============================================

flow assignment_test() {
    simple = "value";
    chained = a = b = "chain";
    result = Agent.run("test");
}

// ============================================
// 复杂嵌套场景测试
// ============================================

flow complex_nested_test() {
    // 嵌套 try-catch
    try {
        loop {
            if (condition) {
                try {
                    result = Agent.run("inner");
                } catch (inner_err) {
                    print(inner_err);
                }
            }
        } until ("done");
    } catch (outer_err) {
        print(outer_err);
    }
}

// ============================================
// 完整 DAG 链测试
// ============================================

flow full_dag_test() {
    // 完整的分叉-合流-分支链
    result = input
        |>> [Researcher, Analyst]
        &>> Reviewer
        >> Editor
        ?? Publisher : Reviser;
}

