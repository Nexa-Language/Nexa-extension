// ============================================
// 带参数的 flow 测试
// ============================================

flow param_flow(task: string, count: int) {
    result = Agent.run(task);
    print(count);
}

flow multi_param_flow(a: string, b: int, c: bool) {
    print(a);
    print(b);
    print(c);
}

protocol ResponseFormat {
    status: "success | error",
    data: "any",
    message: "string"
}

agent SmartBot {
    role: "Assistant",
    prompt: "You are a smart bot.",
    model: "openai/gpt-4",
    memory: "persistent",
    stream: true,
    cache: true,
    experience: "mem.md",
    fallback: ["backup"],
    max_tokens: 1000,
    timeout: 30
}

test "Test SmartBot" {
    result = SmartBot.run("Hello");
    assert "Is a greeting" against result;
}

flow semantic_if_test() {
    semantic_if "是一句日期提示" fast_match r"\d{4}-\d{2}" against req {
        print("Date");
    } else {
        print("Other");
    }

    semantic_if (req, "判断条件") {
        "case1" => print("Action 1"),
        "case2" => print("Action 2")
    }
}

flow match_test() {
    match input {
        intent("查询天气") => handleWeather(),
        intent("设置提醒") => handleReminder(),
        _ => handleDefault()
    }
}

@limit(max_tokens=2000)
@timeout(seconds=60)
@retry(max_attempts=3)
@temperature(value=0.8)
agent DecoratedBot uses Tool1 implements Protocol1 {
    prompt: "I have decorators."
}

flow stdlib_test() {
    result1 = DecoratedBot.run("Hi");
    result2 = DecoratedBot.run_async("Hello");

    std.log("Test log");
    std.http.get("https://example.com");
}
